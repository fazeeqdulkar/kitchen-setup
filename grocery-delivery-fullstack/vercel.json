{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...all].ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(?!api)(.*)$",
      "dest": "/client/index.html"
    }
  ]
}

